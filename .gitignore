# ==========================================
# Python Cache
# ==========================================

__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class

# ==========================================
# Virtual Environment
# ==========================================

venv/
.venv/
env/
ENV/

# ==========================================
# Environment Variables
# ==========================================

.env
.env.*

# ==========================================
# SQLite Database
# ==========================================

database/*.db
database/*.sqlite
database/*.sqlite3

# ==========================================
# Runtime Generated Files
# ==========================================

compressed_files/*
!compressed_files/.gitkeep

decompressed_files/*
!decompressed_files/.gitkeep

archives/*
!archives/.gitkeep

outputs/*
!outputs/.gitkeep

logs/*
!logs/.gitkeep

# ==========================================
# Testing
# ==========================================

.pytest_cache/
.coverage
htmlcov/

# ==========================================
# IDE / Editors
# ==========================================

.vscode/
.idea/

# ==========================================
# Build Files
# ==========================================

build/
dist/
*.egg-info/

# ==========================================
# Jupyter
# ==========================================

.ipynb_checkpoints/

# ==========================================
# OS Files
# ==========================================

.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Temporary Files
# ==========================================

*.tmp
*.bak
*.swp

# ==========================================
# Logs
# ==========================================

*.log